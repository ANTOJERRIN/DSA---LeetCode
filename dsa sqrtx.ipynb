   "source": [
    "class Solution(object):\n",
    "    def mySqrt(self, x):\n",
    "        \"\"\"\n",
    "        :type x: int\n",
    "        :rtype: int\n",
    "        \"\"\"\n",
    "        if x<2:\n",
    "            return x\n",
    "        r=x\n",
    "        while r*r>x:\n",
    "            r=(r+x//r)//2\n",
    "\n",
    "        return r        \n",
    "\n",
    "        "
   ]
  }
