    "k=sns.load_dataset(\"iris\")\n",
    "print(\"\",k.head())\n",
    "print(\"\",k.info())\n",
    "print(\"\",k.describe())\n",
    "print(\"\",k.isnull().sum())\n",
    "\n",
    "sns.histplot(k[\"sepal_length\"],kde=True,bins=20,color=\"blue\")\n",
    "plt.title(\"dist pf sep len\")\n",
    "plt.show()\n",
    "\n",
    "sns.scatterplot(x=\"sepal_length\",y=\"petal_length\",hue=\"species\",data=k)\n",
    "plt.title(\"sep vs pet len by species\")\n",
    "plt.show()\n",
    "sns.pairplot(k,hue=\"species\")\n",
    "plt.suptitle(\"paip\",y=1.02)\n",
    "plt.show()\n",
    "\n",
    "l=sns.load_dataset(\"iris\")\n",
    "num=l.select_dtypes(include='number')\n",
    "corr=num.corr()\n",
    "\n",
    "sns.heatmap(corr,annot=True,cmap=\"coolwarm\")\n",
    "plt.title(\"corr hetamp\")\n",
    "plt.show()"
