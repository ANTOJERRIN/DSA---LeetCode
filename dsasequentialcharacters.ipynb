   "source": [
    "class Solution(object):\n",
    "    def numberOfSpecialChars(self, word):\n",
    "        lower = set()\n",
    "        upper = set()\n",
    "\n",
    "        for ch in word:\n",
    "            if ch.islower():\n",
    "                lower.add(ch)\n",
    "            else:\n",
    "                upper.add(ch.lower())\n",
    "\n",
    "        return len(lower & upper)"
   ]
  }
 ],
