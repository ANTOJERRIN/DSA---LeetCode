   "source": [
    "class Solution(object):\n",
    "    def check(self, nums):\n",
    "        n = len(nums)\n",
    "        drops = 0\n",
    "\n",
    "        for i in range(n):\n",
    "            if nums[i] > nums[(i + 1) % n]:\n",
    "                drops += 1\n",
    "\n",
    "        return drops <= 1"
   ]
  }
 ],
